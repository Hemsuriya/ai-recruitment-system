# ─── Backend ───────────────────────────────────────────────
PORT=5000

# PostgreSQL
DB_HOST=acs_postgres
DB_PORT=5432
DB_USER=postgres
DB_PASSWORD=root
DB_NAME=ai_candidate_screening

# Redis
REDIS_HOST=127.0.0.1
REDIS_PORT=6379

# n8n Webhooks
N8N_BASE_URL=http://localhost:5678
N8N_GET_QUESTIONS_WEBHOOK=/webhook/get-assessment-questions
N8N_UPDATE_STATUS_WEBHOOK=/webhook/update-assessment-status
N8N_SUBMIT_RESULTS_WEBHOOK=/webhook/assessment-results

# ─── AI Services ────────────────────────────────────────────

# ID Verification (FastAPI - port 8000)
REDIS_DB=0
REDIS_TTL_SECONDS=3600
REDIS_ENABLED=true
FALLBACK_DIR=./id_cache

# Video Analysis (Flask - port 5001)
VIDEO_ANALYSIS_PORT=5001
