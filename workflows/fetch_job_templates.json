                                         "mode":  "runOnceForEachItem",
                                         "jsCode":  "let raw = $json.text || \"\";\n\n// 🔥 Remove markdown formatting (```json ... ```)\nraw = raw.replace(/```json/gi, \"\")\n         .replace(/```/g, \"\")\n         .trim();\n\nlet parsed;\n\ntry {\n  parsed = JSON.parse(raw);\n} catch (e) {\n  throw new Error(\"Invalid JSON after cleaning: \" + raw);\n}\n\nreturn {\n  template_key: parsed.template_key,\n  job_title: parsed.job_title,\n  job_description: parsed.job_description,\n  required_skills: parsed.required_skills,\n  number_of_candidates: parsed.number_of_candidates,\n  survey_question_1: parsed.survey_question_1,\n  survey_q1_expected_ans: parsed.survey_q1_expected_answer\n};"
