                      "id":  "fetch-candidates-by-jid",
                      "name":  "Fetch Candidates",
                      "type":  "n8n-nodes-base.postgres",
                      "typeVersion":  2.6,
                      "position":  [
                                       700,
                                       220
                                   ],
                      "credentials":  {
