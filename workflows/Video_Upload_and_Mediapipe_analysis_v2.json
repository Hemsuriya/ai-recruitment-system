      "name": "Upload Video Interview",
      "webhookId": "7db487a7-a087-40cc-a6b5-2a9f50fc9b8e"
    },
    {
      "parameters": {
        "jsCode": "// Extract data from webhook\nconst body = $input.first().json.body;\nconst files = $input.first().binary;\n \nconsole.log('📥 Received upload:', {\n  assessmentId: body.assessmentId,\n  candidateName: body.candidateName,\n  candidateEmail: body.candidateEmail,\n  duration: body.duration,\n  hasVideo: !!files?.video,\n  hasTranscript: !!body.transcript,\n  hasSecurityReport: !!body.securityReport\n});\n \n// Parse JSON strings\nconst transcript = JSON.parse(body.transcript || '{}');\nconst securityReport = JSON.parse(body.securityReport || '{}');\n \nreturn [{\n  json: {\n    assessmentId: body.assessmentId,\n    candidateName: body.candidateName,\n    candidateEmail: body.candidateEmail,\n    duration: parseInt(body.duration) || 0,\n    transcript: transcript,\n    securityReport: securityReport,\n    uploadedAt: new Date().toISOString()\n  },\n  binary: files\n}];"
      },
      "type": "n8n-nodes-base.code",
      "typeVersion": 2,
      "position": [
        -720,
        240
      ],
      "id": "c9ee3bdb-1243-4965-baae-2a43df16768a",
      "name": "Extract Upload Data"
    },
    {
      "parameters": {
        "jsCode": "const uploadData = $input.first().json;\n\nconst previousData = $('Extract Upload Data').first().json;\n \n// Get OneDrive file info - use the direct download URL from Microsoft Graph\n\nconst videoUrl = uploadData['@microsoft.graph.downloadUrl'] || \n\n                 uploadData.webUrl || \n\n                 uploadData.webViewLink || \n\n                 '';\n\nconst videoDriveId = uploadData.id;\n \nconsole.log('✅ Video uploaded to OneDrive:', {\n\n  driveId: videoDriveId,\n\n  downloadUrl: videoUrl ? 'Present' : 'Missing',\n\n  fileName: uploadData.name,\n\n  fileSize: uploadData.size\n\n});\n \nreturn [{\n\n  json: {\n\n    video_assessment_id: previousData.assessmentId,\n\n    candidate_name: previousData.candidateName,\n\n    candidate_email: previousData.candidateEmail,\n\n    video_url: videoUrl,\n\n    video_drive_id: videoDriveId,\n\n    video_duration: previousData.duration,\n\n    full_transcript: previousData.transcript,\n\n    security_report: previousData.securityReport,\n\n    uploaded_at: previousData.uploadedAt\n\n  }\n\n}];"
      },
      "type": "n8n-nodes-base.code",
      "typeVersion": 2,
      "position": [
        -260,
        240
      ],
      "id": "7b1be060-8a85-40a5-a884-b40db1f8b8b6",
      "name": "Prepare Database Data"
    },
