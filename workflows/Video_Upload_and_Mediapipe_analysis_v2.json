        },
        "sendBody": true,
        "specifyBody": "json",
        "jsonBody": "={\n  \"video_drive_id\": \"{{ $('Prepare Database Data').first().json.video_drive_id }}\",\n  \"video_url\": \"{{ $('Prepare Database Data').first().json.video_url }}\",\n  \"assessment_id\": \"{{ $('Prepare Database Data').first().json.video_assessment_id }}\",\n  \"candidate_name\": \"{{ $('Prepare Database Data').first().json.candidate_name }}\",\n  \"candidate_email\": \"{{ $('Prepare Database Data').first().json.candidate_name }}\"\n}",
        "options": {
