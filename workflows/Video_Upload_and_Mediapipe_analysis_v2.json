      "id": "ece8723a-ab2b-4a52-ab38-0d6e36ed90c9",
      "name": "Trigger Video Analysis"
    },
    {
      "parameters": {
        "jsCode": "// Get the analysis response from HTTP Request\nconst analysisResponse = $input.first().json;\n \n// Check if analysis was successful\nif (!analysisResponse.success) {\n  throw new Error(`Video analysis failed: ${analysisResponse.error || 'Unknown error'}`);\n}\n \nconst report = analysisResponse.report;\n \n// Get video info from \"Upload a file\" node (OneDrive)\nconst uploadData = $('Upload a file').first().json;\nconst videoDriveId = uploadData.id;\nconst videoUrl = uploadData['@microsoft.graph.downloadUrl'] || uploadData.webUrl;\n \nreturn [{\n  json: {\n    video_assessment_id: analysisResponse.assessment_id,\n    candidate_name: analysisResponse.candidate_name,\n    candidate_email: report.candidate_email || analysisResponse.candidate_email || 'unknown',\n    video_drive_id: videoDriveId,\n    video_url: videoUrl,\n    // Status\n    analysis_status: 'completed',\n    analysis_completed_at: new Date().toISOString(),\n    // Analysis results (these will be stored as JSONB)\n    emotion_analysis: report.emotion_analysis,\n    attention_metrics: report.attention_metrics,\n    face_detection: report.face_detection,\n    violations_summary: report.violations_summary,\n    full_report: report,\n    // Metadata\n    processing_time_seconds: Math.round(report.session_info.duration_seconds),\n    frames_processed: report.session_info.frames_processed,\n    video_duration_seconds: Math.round(report.session_info.duration_seconds)\n  }\n}];"
      },
      "type": "n8n-nodes-base.code",
      "typeVersion": 2,
      "position": [
        480,
        240
      ],
      "id": "3c2086fc-d2fc-4368-aa96-26f5f38b669a",
      "name": "Trigger Video Analysis1"
    },
